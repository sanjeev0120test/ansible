      "type": "shell",
      "command": "wsl.exe",
      "args": ["-e", "bash", "-c", "mkdir -p ~/.ssh && chmod 700 ~/.ssh && cp -f \"$(wslpath -a '${env:USERPROFILE}/Downloads/key pair.pem')\" ~/.ssh/ec2-keypair.pem && chmod 600 ~/.ssh/ec2-keypair.pem && echo OK: ~/.ssh/ec2-keypair.pem"],
