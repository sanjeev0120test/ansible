# Copy to ".env" in the repo root (gitignored). Do not commit .env.
#
# PEM / SSH key: required ONLY for playbooks that connect over SSH (run_ping, run_site,
# run_audit, user management, etc.). EC2 API playbooks (run_ec2_status, provision,
# stop, start, terminate, nuke) use IAM credentials + AWS_DEFAULT_REGION — no .pem.
#
# ── QUICK START ──────────────────────────────────────────────────────────────
#   cd /mnt/c/dev/ansible/ansible
#   cp -n .env.example .env && nano .env
#   bash scripts/check_setup.sh        # verify setup
#   bash scripts/run_ping.sh           # test connectivity
#   bash scripts/run_site.sh           # configure all hosts
#
# ── EC2 HOST IPs (required for all SSH playbooks) ────────────────────────────
# Public IPv4 of each EC2 instance. Updated automatically by ec2_provision.yml.
EC2_HOST_SERVER1=
EC2_HOST_SERVER2=
EC2_HOST_SERVER3=
EC2_HOST_CLIENT=

# ── SSH KEY (required for SSH playbooks) ─────────────────────────────────────
# Path to your EC2 key pair private .pem file inside WSL.
# If left blank, scripts look for ~/.ssh/ec2-keypair.pem automatically.
# Example: /home/yourname/.ssh/my-key.pem
# Paths with spaces are handled automatically (copied to ~/.ec2-ansible-nospace.pem).
EC2_SSH_PRIVATE_KEY=

# ── MANAGED USER PUBLIC KEY (optional) ───────────────────────────────────────
# Override default path for the SSH public key installed on managed users.
# Default: .keys/appoperator_ed25519.pub (generate: see WSL_COMMANDS.txt section C)
# ANSIBLE_MANAGED_PUBKEY_PATH=

# ── AWS CREDENTIALS (required only for EC2 playbooks) ────────────────────────
# Needed by: ec2_provision, ec2_stop, ec2_start, ec2_terminate, ec2_status
# Get from: AWS Console → IAM → Users → Security Credentials → Access keys
# IAM policy: attach iam/ec2-ansible-lab-policy.json (or AmazonEC2FullAccess for labs)
# If you see UnauthorizedOperation on ec2:DescribeInstances, the user lacks EC2 permissions.
#
# Leave blank if using AWS CLI config (~/.aws/credentials) or IAM instance role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS region for EC2 API calls — must match the region in the EC2 console URL, e.g.
# https://us-east-1.console.aws.amazon.com/ec2/... → us-east-1 (US East N. Virginia)
AWS_DEFAULT_REGION=us-east-1

# ── EC2 INSTANCE SETTINGS (required for ec2_provision only) ──────────────────
# REQUIRED for run_ec2_provision.sh — without this, instance launch fails immediately.
# Name of your EC2 key pair (AWS Console → EC2 → Key Pairs → "Key pair name" column).
# This is the NAME string only, NOT the path to your .pem file.
# Example: my-ec2-keypair   (same name you chose when you created/downloaded the .pem)
EC2_KEY_PAIR_NAME=

# Number of instances to provision (1–4). Free tier: 2 recommended.
# Free tier hours vary by account (often 750 h/month for one eligible size). Stop when idle.
# → STOP when not in use: bash scripts/run_ec2_stop.sh
EC2_INSTANCE_COUNT=2

# AWS Free Tier lab standard: t3.micro in us-east-1 (do not change for documented free-tier path).
EC2_INSTANCE_TYPE=t3.micro
